{
  "compilerOptions": {
    "target": "es2019",
    "module": "CommonJS",

    "rootDir": ".",
    "outDir": "./dist",

    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,

    "strict": true,
    "skipLibCheck": true,

    "resolveJsonModule": true,
    "types": ["node"]
  }
}